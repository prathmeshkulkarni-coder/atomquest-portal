# Copy to .env for local / Docker Compose (never commit .env)
# cp .env.example .env

# Production (Render / Railway): set DATABASE_URL from host dashboard
# DATABASE_URL=postgresql://user:pass@host:5432/dbname
# DATABASE_SSL=true

# Database (local Docker)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password123
POSTGRES_DB=atomquest_db
DB_USER=postgres
DB_PASSWORD=password123
DB_HOST=db
DB_NAME=atomquest_db
DB_PORT=5432

# API
PORT=5000
JWT_SECRET=change_me_to_a_long_random_string
NODE_ENV=development

# BRD cycle: true = all windows open (demo); false = strict calendar
CYCLE_DEMO_MODE=true

# Production Docker (docker-compose.prod.yml)
APP_PORT=8080
# CORS_ORIGIN=https://your-domain.com
